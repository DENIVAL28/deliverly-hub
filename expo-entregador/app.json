{
  "expo": {
    "name": "Entregador DH",
    "slug": "entregador-dh",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "scheme": "entregadordh",
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#f97316"
      },
      "package": "com.deliverlyhub.entregador",
      "newArchEnabled": false,
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.VIBRATE",
        "android.permission.INTERNET"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "*.vercel.app",
              "pathPattern": "/entregador/.*"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Precisamos da sua localização para mostrar sua posição ao restaurante.",
          "locationWhenInUsePermission": "Precisamos da sua localização para mostrar sua posição ao restaurante."
        }
      ]
    ],
    "extra": {
